FROM eclipse-temurin:21-jre-alpine AS builder
WORKDIR /build
COPY . .
RUN apk add --no-cache maven && \
    mvn clean package -DskipTests -q

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=builder /build/dashboard-service/target/dashboard-service.jar .
EXPOSE 8084
CMD ["java", "-Dspring.profiles.active=docker", "-jar", "dashboard-service.jar"]
