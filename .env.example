# Copy file này thành .env và điền key thật vào để chạy app
GEMINI_API_KEY=your_google_gemini_api_key_here
DB_PASSWORD=your_database_password_here
JWT_PRIVATE_KEY=your_base64_pkcs8_private_key_here
JWT_PUBLIC_KEY=your_base64_x509_public_key_here
JWT_SIGNING_KID=mhsa-key-1
JWT_ISSUER=mhsa-auth
JWT_AUDIENCE=mhsa-api
JWT_ALLOW_HS256_FALLBACK=false

# Docker host ports (used by docker-compose.yml)
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
PGADMIN_HOST_PORT=5050
RABBITMQ_AMQP_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672

# Spring Boot API port
SERVER_PORT=8080